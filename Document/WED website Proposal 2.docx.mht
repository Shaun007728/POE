div.TableContainer.Rtl > table.Table > div.SelectTableHandle { left: 0px; right: -20px; }

.AIFeedbackUnfocused, .Themed .AIFeedbackUnfocused { background-color: rgb(240, 240, 240); }

.AIFeedbackUnfocusedDarkMode, .Themed .AIFeedbackUnfocusedDarkMode { background-color: rgb(66, 66, 66); }

.AIFeedbackFocused, .Themed .AIFeedbackFocused { background-image: linear-gradient(270deg, rgba(174, 115, 242, 0.25) 1.05%, rgba(96, 149, 245, 0.25) 99.85%); }

#CopilotCursorAppRoot { height: 100%; top: 0px; }

#CopilotComprehensionAppRoot { background: none; height: 0px; pointer-events: none; position: absolute; width: 0px; }

#CopilotComprehensionCardRoot { margin: 6px auto -13px; }

.CopilotComprehensionSelectableTextContent :not(a[role="button"]) { user-select: text; }

#CopilotComposeLaunchpadRoot { align-items: center; display: flex; flex-direction: column; margin-top: 19px; position: relative; width: 100%; z-index: 100; }

#CopilotComposeLaunchpadRoot.CopilotComposeLaunchpadRootRockSteady { margin-bottom: -3px; margin-top: 16px; }

#CopilotComposeAppRoot { height: 0px; width: 0px; }

#CopilotComposeAppRoot, #CopilotComposeFloatieRoot { background: none; pointer-events: none; position: absolute; }

#CopilotComposeFloatieRoot { width: 100%; }

#CopilotComposeReviewToolbarRoot { background: none; bottom: 20px; left: 50%; position: absolute; transform: translateX(-50%); }

.WACViewPanel #CopilotComposeFloatieRoot, .WACViewPanel #CopilotComposeReviewToolbarRoot { z-index: 100; }

.CopilotComposeIndicator { position: absolute; z-index: 2147483647; }

.CopilotComposeIndicator--ltr { transform: translateX(-100%) translateY(-50%); }

.CopilotComposeIndicator--rtl { transform: translateY(-50%); }

.CopilotComposeAnchor { left: 0px; pointer-events: none; position: absolute; width: 100%; }

.CopilotComposeAnchor--cover { height: 100%; top: 0px; }

.CopilotComposeAnchor--below { bottom: 0px; height: 0px; }

.CopilotComposePlaceholder::after { color: var(--clrPlaceholderText,#BDBDBD); content: attr(data-copilot-compose-placeholder); font-family: "Segoe UI", "Segoe UI Web", Arial, Verdana, sans-serif; font-size: min(14px, 100%); font-weight: 400; left: 4px; right: 12px; z-index: -1; }

.PredictionGhostText { display: inline-flex; position: absolute; }

.PredictionGhostText::after { color: var(--clrPlaceholderText,#BDBDBD); content: attr(data-ghost-text); white-space: break-spaces; }

.PredictionGhostTextContainer { position: static; visibility: visible; }

.CopilotComposeDraggable { cursor: grab; }

.CopilotHighlightTransition { transition: background 0.7s linear; }

div#FloatingContainersOuterSurface { grid-column: 2; }

div#FloatingContainersOuterSurface, div#FloatingContainersOuterSurfaceHostedUi { grid-row: 2; height: 100%; position: relative; top: 0px; transition: opacity 0.2s linear; z-index: 1; }

div#FloatingContainersOuterSurfaceHostedUi { grid-column: 3 !important; }

div#FloatingContainersHost { height: 100%; transform: translateZ(0px); width: 100%; }

div#menuPasteOptions svg > .OfficeIconColors_m22 { fill: rgb(58, 58, 56); }

.LineNumber { font-size: 11pt; position: absolute; visibility: visible; }

li.OutlineElement.checklist p span.ListMarkerWrappingSpan, li.OutlineElement.checklist.checked p span.TextRun { opacity: 0.7; }

.FootnoteEndnoteActionBarFormattingButton:focus, .FootnoteEndnoteActionBarNavigationButton:focus, .usehover .FootnoteEndnoteActionBarFormattingButton:hover, .usehover .FootnoteEndnoteActionBarNavigationButton:hover { outline: rgb(0, 0, 0) solid 1px; }

#mobile-search-bar { bottom: 0px; left: 0px; position: fixed; right: 0px; z-index: 1000; }

span.CanvasProofingHighlight, span.CanvasProofingSquiggle { height: 100%; position: absolute; width: 100%; }

.SidetrackCard { opacity: 0; position: absolute; transition: opacity 0.4s cubic-bezier(0.1, 0.9, 0.2, 1); }

.SidetrackCardVisible { opacity: 1; }

.SidetrackCardPositioned { transition: opacity 0.4s cubic-bezier(0.1, 0.9, 0.2, 1), top 0.4s cubic-bezier(0.1, 0.9, 0.2, 1), left 0.4s cubic-bezier(0.1, 0.9, 0.2, 1); }

